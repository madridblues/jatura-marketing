---
import PublicHeader from '@/components/PublicHeader';
import PublicFooter from '@/components/PublicFooter';
import Analytics from '@vercel/analytics/astro';
import '@/styles/global.css';

const SITE_URL = 'https://jatura.com';

interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  canonicalUrl?: string;
  schemaOrg?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description = 'Jatura is the AI-native applicant tracking system built for modern hiring teams.',
  ogTitle,
  ogDescription,
  ogImage = `${SITE_URL}/og-image.png`,
  ogType = 'website',
  canonicalUrl,
  schemaOrg,
  noindex = false,
} = Astro.props;

// Auto-derive canonical from current pathname if not explicitly provided
const canonical = canonicalUrl ?? `${SITE_URL}${Astro.url.pathname}`;

// Global base schema injected on every page (WebSite + Organization entity graph)
const baseSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${SITE_URL}/#website`,
      "url": SITE_URL,
      "name": "Jatura",
      "description": "All-in-one recruiting platform with AI embedded in every layer",
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": `${SITE_URL}/blog?q={search_term_string}` },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "@id": `${SITE_URL}/#organization`,
      "name": "Jatura",
      "url": SITE_URL,
      "logo": {
        "@type": "ImageObject",
        "url": `${SITE_URL}/logo.png`,
        "width": 200,
        "height": 50
      },
      "sameAs": [
        "https://twitter.com/jatura",
        "https://linkedin.com/company/jatura",
        "https://www.g2.com/products/jatura"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "url": `${SITE_URL}/support`
      }
    }
  ]
};

// Merge page-level schema into @graph if it uses @graph, or wrap as single item
let pageSchemaItems: object[] = [];
if (schemaOrg) {
  if (Array.isArray(schemaOrg)) {
    pageSchemaItems = schemaOrg;
  } else if (typeof schemaOrg === 'object' && '@graph' in schemaOrg) {
    pageSchemaItems = (schemaOrg as any)['@graph'];
  } else {
    pageSchemaItems = [schemaOrg];
  }
}

const mergedSchema = {
  "@context": "https://schema.org",
  "@graph": [...(baseSchema['@graph']), ...pageSchemaItems]
};
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap" rel="stylesheet" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Jatura" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@jatura" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD — merged base + page schema in single @graph -->
    <script type="application/ld+json" set:html={JSON.stringify(mergedSchema)} />

    <!-- PostHog — feature flags + analytics -->
    <script>
