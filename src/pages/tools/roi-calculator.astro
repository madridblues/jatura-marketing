---
export const prerender = true;
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import ROICalculatorPage from '@/components/islands/ROICalculatorPage';

const title = "ROI Calculator | Calculate Hiring Cost Savings | Jatura ATS";
const description = "Free ROI calculator for USA, UK, and Europe. Estimate cost savings by switching to Jatura ATS with region-specific metrics. Calculate time-to-hire reduction, cost per hire savings, and recruiter productivity gains.";

const schemaOrg = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jatura.com" },
      { "@type": "ListItem", "position": 2, "name": "Free Recruiting Tools", "item": "https://jatura.com/tools" },
      { "@type": "ListItem", "position": 3, "name": "ATS ROI Calculator", "item": "https://jatura.com/tools/roi-calculator" }
    ]
  },
  {
    "@type": "WebApplication",
    "name": "ATS ROI Calculator",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "description": "Free calculator to estimate ROI from switching to Jatura ATS",
    "url": "https://jatura.com/tools/roi-calculator"
  }
];
---

<MarketingLayout {title} {description} {schemaOrg}>
  <ROICalculatorPage client:load />
</MarketingLayout>
