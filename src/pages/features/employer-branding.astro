---
export const prerender = true;
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Heart, Users, Star, TrendingUp, MessageSquare, Video, Globe, Sparkles, ArrowRight, CheckCircle, Building2, Award, Zap, Target, BarChart3, Share2 } from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';

const title = "Employer Branding | Jatura - Build Your Talent Magnet";
const description = "Attract more qualified candidates with a compelling employer brand. Jatura's tools include a career page builder, culture content sections, employee testimonials, and DEI transparency metrics.";

const schemaOrg = [
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jatura.com" },
      { "@type": "ListItem", "position": 2, "name": "Features", "item": "https://jatura.com/features" },
      { "@type": "ListItem", "position": 3, "name": "Employer Branding", "item": "https://jatura.com/features/employer-branding" }
    ]
  },
  {
    "@type": "SoftwareApplication",
    "name": "Jatura ATS",
    "@id": "https://jatura.com/#software",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "description": "Free plan available" },
    "featureList": ["Career Page Builder", "Culture Content Sections", "Employee Testimonials", "DEI Metrics Display", "Social Media Sharing", "Branded Email Templates", "Video Integration"],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "ratingCount": "247", "bestRating": "5" }
  }
];
---

<MarketingLayout {title} {description} {schemaOrg}>

      {/* Hero Section */}
      <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-gradient-to-b from-slate-50 to-white dark:from-slate-900/50 dark:to-slate-950">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-16">
            <Badge
              variant="secondary"
              class="mb-6 px-5 py-2 text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100"
            >
              <Heart class="w-4 h-4 mr-2" />
              Employer Branding
            </Badge>
            <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
              Turn your company into<br />a talent magnet
            </h1>
            <p class="text-xl sm:text-2xl text-slate-600 dark:text-slate-400 max-w-4xl mx-auto mb-12 leading-relaxed">
              Showcase your culture, tell authentic stories, and create candidate experiences that make top talent choose you over competitors.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/signup">
                <Button
                  size="lg"
                  class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 px-10 py-6 text-lg group shadow-lg"
                >
                  Start free trial
                  <ArrowRight class="ml-2 h-5 w-5 group-hover:translate-x-1 transition" />
                </Button>
              </a>
              <a href="/pricing">
                <Button
                  size="lg"
                  variant="outline"
                  class="px-10 py-6 text-lg border-slate-300 dark:border-slate-700"
                >
                  View pricing
                </Button>
              </a>
            </div>
          </div>

          {/* Stats */}
          <div class="grid md:grid-cols-3 gap-8 mt-20">
            <div class="text-center">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-2">94%</div>
              <p class="text-slate-600 dark:text-slate-400">
                Increase in qualified applications
              </p>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-2">3x</div>
              <p class="text-slate-600 dark:text-slate-400">
                More engaged passive candidates
              </p>
            </div>
            <div class="text-center">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-2">89%</div>
              <p class="text-slate-600 dark:text-slate-400">
                Report faster hiring process
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* Features Grid */}
      <section class="py-28 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-20">
            <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-6">
              Everything you need to build a magnetic employer brand
            </h2>
            <p class="text-xl text-slate-600 dark:text-slate-400 max-w-3xl mx-auto">
              Stand out from competitors and attract the talent you need
            </p>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
              <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
                <Globe class="w-7 h-7 text-slate-900 dark:text-white" />
              </div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
                Branded Career Sites
              </h3>
              <p class="text-slate-600 dark:text-slate-400">
                Create beautiful, mobile-optimized career pages that reflect your company culture and convert visitors into applicants.
              </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
              <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
                <Users class="w-7 h-7 text-slate-900 dark:text-white" />
              </div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
                Employee Stories
              </h3>
              <p class="text-slate-600 dark:text-slate-400">
                Showcase real employee experiences with photos, videos, and testimonials that give candidates an authentic look inside your company.
              </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
              <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
                <MessageSquare class="w-7 h-7 text-slate-900 dark:text-white" />
              </div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
                Candidate Chat
              </h3>
              <p class="text-slate-600 dark:text-slate-400">
                Start conversations with interested talent instantly. Answer questions in real-time and build relationships before they apply.
              </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
              <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
                <Target class="w-7 h-7 text-slate-900 dark:text-white" />
              </div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
                Talent Community
              </h3>
              <p class="text-slate-600 dark:text-slate-400">
                Build and nurture a talent pool of interested candidates. Keep them engaged with automated campaigns until the perfect role opens up.
              </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
              <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
                <Share2 class="w-7 h-7 text-slate-900 dark:text-white" />
              </div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
                Social Amplification
              </h3>
              <p class="text-slate-600 dark:text-slate-400">
                Make it easy for employees to share job openings with their networks. Turn your team into brand ambassadors.
              </p>
            </div>

            <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
              <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
                <BarChart3 class="w-7 h-7 text-slate-900 dark:text-white" />
              </div>
              <h3 class="text-xl font-semibold text-slate-900 dark:text-white mb-4">
                Candidate Experience Metrics
              </h3>
              <p class="text-slate-600 dark:text-slate-400">
                Track NPS scores and feedback to continuously improve your candidate journey and employer brand perception.
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* How It Works */}
      <section class="py-28 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-900/50">
        <div class="max-w-7xl mx-auto">
          <div class="text-center mb-20">
            <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-6">
              Build your employer brand in three steps
            </h2>
          </div>

          <div class="grid lg:grid-cols-3 gap-12">
            <div>
              <div class="w-12 h-12 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full flex items-center justify-center font-bold text-lg mb-6">
                1
              </div>
              <h3 class="text-2xl font-semibold text-slate-900 dark:text-white mb-4">
                Showcase Your Culture
              </h3>
              <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">
                Create compelling career pages that highlight your mission, values, benefits, and what makes your workplace unique.
              </p>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Custom page builder</span>
                </div>
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Photo and video galleries</span>
                </div>
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Mobile-optimized design</span>
                </div>
              </div>
            </div>

            <div>
              <div class="w-12 h-12 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full flex items-center justify-center font-bold text-lg mb-6">
                2
              </div>
              <h3 class="text-2xl font-semibold text-slate-900 dark:text-white mb-4">
                Engage Candidates
              </h3>
              <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">
                Start conversations through live chat, build talent communities, and nurture relationships with automated campaigns.
              </p>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Real-time candidate chat</span>
                </div>
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Talent pool nurturing</span>
                </div>
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Email campaigns</span>
                </div>
              </div>
            </div>

            <div>
              <div class="w-12 h-12 bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-full flex items-center justify-center font-bold text-lg mb-6">
                3
              </div>
              <h3 class="text-2xl font-semibold text-slate-900 dark:text-white mb-4">
                Measure & Improve
              </h3>
              <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">
                Track candidate experience metrics, gather feedback, and continuously refine your employer brand strategy.
              </p>
              <div class="space-y-3">
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">NPS surveys</span>
                </div>
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Application analytics</span>
                </div>
                <div class="flex items-start gap-3">
                  <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
                  <span class="text-slate-600 dark:text-slate-400">Source tracking</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Why It Matters */}
      <section class="py-28 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
          <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div>
              <h2 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white mb-8">
                Why employer branding matters
              </h2>
              <div class="space-y-6 text-lg text-slate-600 dark:text-slate-400">
                <p>
                  In today's competitive talent market,{" "}
                  <strong class="text-slate-900 dark:text-white">
                    your employer brand is what sets you apart
                  </strong>
                  . Candidates research companies before applying — and they choose employers who align with their values.
                </p>
                <p>
                  A strong employer brand doesn't just attract more applicants. It attracts{" "}
                  <strong class="text-slate-900 dark:text-white">
                    the right applicants
                  </strong>{" "}
                  — people who are genuinely excited about your mission and culture.
                </p>
                <p>
                  Companies with compelling employer brands see higher application rates, faster time-to-hire, and better retention. They spend less on recruiting because top talent comes to them.
                </p>
              </div>
            </div>

            <div class="bg-white dark:bg-slate-900 rounded-3xl p-10 border border-slate-200 dark:border-slate-800 shadow-xl">
              <div class="space-y-8">
                <div>
                  <div class="flex items-center gap-3 mb-3">
                    <TrendingUp class="w-6 h-6 text-emerald-600" />
                    <h4 class="text-lg font-semibold text-slate-900 dark:text-white">
                      50% Reduction in Cost-per-Hire
                    </h4>
                  </div>
                  <p class="text-slate-600 dark:text-slate-400">
                    Strong employer brands attract passive candidates organically, reducing reliance on expensive job boards.
                  </p>
                </div>

                <div>
                  <div class="flex items-center gap-3 mb-3">
                    <Star class="w-6 h-6 text-emerald-600" />
                    <h4 class="text-lg font-semibold text-slate-900 dark:text-white">
                      2x More Applications
                    </h4>
                  </div>
                  <p class="text-slate-600 dark:text-slate-400">
                    Companies with great employer brands receive twice as many applications per job posting.
                  </p>
                </div>

                <div>
                  <div class="flex items-center gap-3 mb-3">
                    <Award class="w-6 h-6 text-emerald-600" />
                    <h4 class="text-lg font-semibold text-slate-900 dark:text-white">
                      28% Lower Turnover
                    </h4>
                  </div>
                  <p class="text-slate-600 dark:text-slate-400">
                    When candidates understand your culture upfront, they're more likely to stay long-term.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section class="py-28 px-4 sm:px-6 lg:px-8 bg-slate-900 dark:bg-white">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-4xl sm:text-5xl font-bold text-white dark:text-slate-900 mb-6">
            Ready to build your employer brand?
          </h2>
          <p class="text-xl text-slate-300 dark:text-slate-600 mb-10">
            Start attracting top talent with a compelling employer brand they can't ignore.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/signup">
              <Button
                size="lg"
                class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800 px-10 py-6 text-lg"
              >
                Start free trial
                <ArrowRight class="ml-2 h-5 w-5" />
              </Button>
            </a>
            <a href="/pricing">
              <Button
                size="lg"
                variant="outline"
                class="px-10 py-6 text-lg border-slate-700 dark:border-slate-300 text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100"
              >
                View pricing
              </Button>
            </a>
          </div>
        </div>
      </section>

</MarketingLayout>
