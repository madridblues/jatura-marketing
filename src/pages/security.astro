---
export const prerender = true;
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { ArrowLeft, Shield, Lock, Server, Eye, CheckCircle } from 'lucide-react';

const schemaOrg = [{ "@type": "WebPage", "name": "Security at Jatura", "url": "https://jatura.com/security" }];
---

<MarketingLayout title="Security | Jatura" description="Learn about Jatura's security practices, certifications, and how we protect your data. Enterprise-grade security for your hiring data." {schemaOrg}>
  <article class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white mb-8 group"
      >
        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition" />
        Back to home
      </a>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
        Security at Jatura
      </h1>

      <p class="text-xl text-slate-600 dark:text-slate-400 mb-12">
        Your hiring data deserves enterprise-grade protection. Here's how we keep it safe.
      </p>

      <div class="grid sm:grid-cols-2 gap-6 mb-16">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
          <Shield class="w-10 h-10 text-slate-900 dark:text-white mb-4" />
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">SOC 2 Type II</h3>
          <p class="text-slate-600 dark:text-slate-400">
            Our infrastructure meets SOC 2 Type II standards for security, availability, and confidentiality.
          </p>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
          <Lock class="w-10 h-10 text-slate-900 dark:text-white mb-4" />
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Encryption</h3>
          <p class="text-slate-600 dark:text-slate-400">
            All data is encrypted in transit (TLS 1.3) and at rest (AES-256). Sensitive fields receive additional encryption.
          </p>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
          <Server class="w-10 h-10 text-slate-900 dark:text-white mb-4" />
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Infrastructure</h3>
          <p class="text-slate-600 dark:text-slate-400">
            Hosted on enterprise-grade cloud infrastructure with automated backups, redundancy, and disaster recovery.
          </p>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8">
          <Eye class="w-10 h-10 text-slate-900 dark:text-white mb-4" />
          <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">Monitoring</h3>
          <p class="text-slate-600 dark:text-slate-400">
            24/7 security monitoring, intrusion detection, and automated alerting for suspicious activity.
          </p>
        </div>
      </div>

      <div class="prose prose-slate dark:prose-invert max-w-none">
        <section class="mb-12">
          <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">Data Protection</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Role-based access control (RBAC) for all team members</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Session management with secure cookie handling</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Automated consent logging and audit trails</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Password hashing using industry-standard algorithms</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Multi-device session management</span>
            </div>
          </div>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">Application Security</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Regular security audits and penetration testing</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Input validation and SQL injection prevention</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Cross-site scripting (XSS) protection</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Rate limiting and DDoS protection</span>
            </div>
          </div>
        </section>

        <section class="mb-12">
          <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">Compliance</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">GDPR compliant with full data subject rights support</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">CCPA compliant for California residents</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Privacy Hub for candidate data management</span>
            </div>
            <div class="flex items-start gap-3">
              <CheckCircle class="w-5 h-5 text-emerald-600 flex-shrink-0 mt-0.5" />
              <span class="text-slate-600 dark:text-slate-400">Data Processing Agreements available</span>
            </div>
          </div>
        </section>

        <section class="mb-8">
          <h2 class="text-2xl font-semibold text-slate-900 dark:text-white mb-4">Report a Vulnerability</h2>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            We take security seriously and welcome responsible disclosure. If you've found a security vulnerability, please visit our{" "}
            <a href="/vulnerability-disclosure" class="text-blue-600 dark:text-blue-400 hover:underline">Vulnerability Disclosure</a>{" "}
            page or email us at{" "}
            <a href="mailto:security@jatura.com" class="text-blue-600 dark:text-blue-400 hover:underline">security@jatura.com</a>.
          </p>
        </section>
      </div>
    </div>
  </article>
</MarketingLayout>
