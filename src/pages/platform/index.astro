---
export const prerender = true;
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import {
  Brain, Workflow, Users, MessageSquare, Calendar, BarChart3,
  Shield, Zap, Globe, CheckCircle, Star, Target, FileText,
  Mail, Phone, Clock, TrendingUp, Award, Sparkles, ArrowRight
} from 'lucide-react';

const schemaOrg = [
  {
    "@type": "Article",
    "headline": "Complete Hiring Platform - Everything You Need to Hire",
    "description": "Comprehensive hiring platform with AI-powered screening, custom workflows, team collaboration, and candidate portals.",
    "author": { "@type": "Organization", "name": "Jatura" },
    "publisher": { "@type": "Organization", "name": "Jatura", "logo": { "@type": "ImageObject", "url": "https://jatura.com/logo.png" } },
    "datePublished": "2025-11-13"
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://jatura.com" },
      { "@type": "ListItem", "position": 2, "name": "Platform", "item": "https://jatura.com/platform" }
    ]
  }
];
---

<MarketingLayout
  title="Platform | Jatura"
  description="Comprehensive hiring platform with AI-powered screening, custom workflows, team collaboration, and candidate portals. Everything you need to hire better, faster."
  ogTitle="Platform | Jatura"
  ogDescription="Comprehensive hiring platform with AI-powered screening, custom workflows, team collaboration, and candidate portals. Everything you need to hire better, faster."
  canonicalUrl="https://jatura.com/platform"
  {schemaOrg}
>
  <!-- Hero Section -->
  <section class="pt-24 pb-20 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-7xl mx-auto text-center">
      <Badge variant="secondary" class="mb-8 px-5 py-2 text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-900 dark:text-slate-100 border-slate-200 dark:border-slate-700">
        <Sparkles className="w-4 h-4 mr-2" />
        Complete hiring platform
      </Badge>
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-slate-900 dark:text-white mb-6 leading-tight">
        Everything you need to hire
        <span class="block mt-2">in one <span class="text-blue-500">complete</span> platform</span>
      </h1>
      <p class="text-lg sm:text-xl md:text-2xl text-slate-600 dark:text-slate-400 max-w-4xl mx-auto mb-10 md:mb-12 leading-relaxed px-4">
        From AI screening to automated workflows, candidate portals to team collaboration. Jatura provides all the tools modern hiring teams need to succeed.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/login">
          <Button size="lg" class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 hover:bg-slate-800 dark:hover:bg-slate-100 px-10 py-6 text-lg group shadow-lg">
            Start free trial
            <ArrowRight className="ml-2 h-5 w-5 group-hover:translate-x-1 transition" />
          </Button>
        </a>
        <a href="/pricing">
          <Button size="lg" variant="outline" class="px-10 py-6 text-lg border-slate-300 dark:border-slate-700 text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800">
            View pricing
          </Button>
        </a>
      </div>
      <div class="mt-8">
        <a href="/features/applicant-tracking-system" class="text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white font-medium inline-flex items-center gap-2 group">
          Learn more about our Applicant Tracking System
          <ArrowRight className="w-4 h-4 group-hover:translate-x-1 transition" />
        </a>
      </div>
    </div>
  </section>

  <!-- Core Features -->
  <section class="py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 md:mb-20">
        <p class="text-xs sm:text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">
          [01] Core Platform
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-4 md:mb-6 leading-tight">
          Powerful automation
        </h2>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 max-w-3xl leading-relaxed">
          Built for speed, designed for results
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 hover:border-slate-300 dark:hover:border-slate-700 transition-all">
          <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
            <Brain className="w-7 h-7 text-slate-900 dark:text-white" />
          </div>
          <h3 class="text-xl font-semibold mb-4 text-slate-900 dark:text-white">AI-Powered Screening</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Automatically score and rank candidates based on custom criteria. AI analyzes resumes, skills, and experience to surface the best matches.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 hover:border-slate-300 dark:hover:border-slate-700 transition-all">
          <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
            <Workflow className="w-7 h-7 text-slate-900 dark:text-white" />
          </div>
          <h3 class="text-xl font-semibold mb-4 text-slate-900 dark:text-white">Custom Pipeline & Automation</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Design your perfect hiring workflow with configurable stages, automated triggers, and smart routing to keep candidates moving.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 hover:border-slate-300 dark:hover:border-slate-700 transition-all">
          <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
            <Users className="w-7 h-7 text-slate-900 dark:text-white" />
          </div>
          <h3 class="text-xl font-semibold mb-4 text-slate-900 dark:text-white">Team Collaboration</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Role-based access, shared feedback, scorecards, and real-time notifications keep your hiring team aligned and productive.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 hover:border-slate-300 dark:hover:border-slate-700 transition-all">
          <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
            <MessageSquare className="w-7 h-7 text-slate-900 dark:text-white" />
          </div>
          <h3 class="text-xl font-semibold mb-4 text-slate-900 dark:text-white">Bidirectional Communication</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Send and receive SMS and emails directly from the platform. Smart routing, templates, and full conversation history included.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 hover:border-slate-300 dark:hover:border-slate-700 transition-all">
          <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
            <Calendar className="w-7 h-7 text-slate-900 dark:text-white" />
          </div>
          <h3 class="text-xl font-semibold mb-4 text-slate-900 dark:text-white">Smart Scheduling</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Candidates can self-schedule interviews based on your availability. Automated reminders and calendar sync keep everyone on track.
          </p>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 hover:border-slate-300 dark:hover:border-slate-700 transition-all">
          <div class="w-14 h-14 bg-slate-100 dark:bg-slate-800 rounded-xl flex items-center justify-center mb-6">
            <BarChart3 className="w-7 h-7 text-slate-900 dark:text-white" />
          </div>
          <h3 class="text-xl font-semibold mb-4 text-slate-900 dark:text-white">Advanced Analytics</h3>
          <p class="text-slate-600 dark:text-slate-400 leading-relaxed">
            Track time-to-hire, source effectiveness, pipeline health, and recruiter performance with real-time dashboards and reports.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Candidate Experience -->
  <section class="py-28 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-8 lg:gap-20 items-center">
        <div>
          <p class="text-xs sm:text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">
            [02] Candidate Portal
          </p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-6 md:mb-8 leading-tight">
            Experience that converts
          </h2>
          <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 mb-8 md:mb-12 leading-relaxed">
            Give candidates a best-in-class experience with our mobile-first portal, status tracking, and transparent communication.
          </p>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0 mt-1" />
              <div>
                <h4 class="font-semibold text-lg text-slate-900 dark:text-white mb-2">Apply in 60 Seconds</h4>
                <p class="text-slate-600 dark:text-slate-400 leading-relaxed">Mobile-optimized application forms with smart autofill and validation</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0 mt-1" />
              <div>
                <h4 class="font-semibold text-lg text-slate-900 dark:text-white mb-2">Real-Time Status Updates</h4>
                <p class="text-slate-600 dark:text-slate-400 leading-relaxed">Candidates see their progress through your pipeline with timeline tracking</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0 mt-1" />
              <div>
                <h4 class="font-semibold text-lg text-slate-900 dark:text-white mb-2">Self-Service Portal</h4>
                <p class="text-slate-600 dark:text-slate-400 leading-relaxed">Upload documents, complete assessments, and message recruiters. All in one place.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0 mt-1" />
              <div>
                <h4 class="font-semibold text-lg text-slate-900 dark:text-white mb-2">GDPR & CCPA Compliant</h4>
                <p class="text-slate-600 dark:text-slate-400 leading-relaxed">Privacy hub with consent management and data request handling</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-white dark:bg-slate-900 rounded-3xl p-10 border border-slate-200 dark:border-slate-800 shadow-xl">
          <div class="bg-slate-50 dark:bg-slate-800 rounded-2xl p-8">
            <div class="flex items-center gap-4 mb-8">
              <div class="w-16 h-16 bg-gradient-to-br from-slate-700 to-slate-900 dark:from-slate-300 dark:to-slate-100 rounded-full"></div>
              <div class="flex-1">
                <div class="h-4 w-40 bg-slate-200 dark:bg-slate-700 rounded mb-2"></div>
                <div class="h-3 w-32 bg-slate-100 dark:bg-slate-800 rounded"></div>
              </div>
            </div>
            <div class="space-y-4">
              <div class="flex items-center justify-between p-4 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-700">
                <div class="flex items-center gap-4">
                  <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white" />
                  <span class="text-sm font-medium text-slate-900 dark:text-white">Application Submitted</span>
                </div>
              </div>
              <div class="flex items-center justify-between p-4 bg-slate-900 dark:bg-white rounded-xl border-2 border-slate-900 dark:border-white">
                <div class="flex items-center gap-4">
                  <Clock className="w-6 h-6 text-white dark:text-slate-900" />
                  <span class="text-sm font-medium text-white dark:text-slate-900">Under Review</span>
                </div>
              </div>
              <div class="flex items-center justify-between p-4 bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-700 opacity-50">
                <div class="flex items-center gap-4">
                  <Calendar className="w-6 h-6 text-slate-400" />
                  <span class="text-sm font-medium text-slate-600 dark:text-slate-400">Interview</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Advanced Features -->
  <section class="py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 md:mb-20">
        <p class="text-xs sm:text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">
          [03] Advanced Capabilities
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-4 md:mb-6 leading-tight">
          Enterprise-grade features
        </h2>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 max-w-3xl leading-relaxed">
          For scaling teams that need more
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-4 md:gap-6">
        <div class="bg-slate-900 dark:bg-white text-white dark:text-slate-900 rounded-3xl p-10">
          <Target className="w-12 h-12 mb-6 opacity-90" />
          <h3 class="text-3xl font-semibold mb-4">Talent Pooling & Tagging</h3>
          <p class="mb-8 opacity-90 text-lg leading-relaxed">
            Build custom talent pools and organize candidates with AI-powered tag suggestions. Bulk actions and smart filtering make managing thousands of candidates effortless.
          </p>
          <div class="flex items-center gap-3 text-sm opacity-90">
            <Star className="w-5 h-5" />
            <span>AI suggests relevant tags automatically</span>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-10">
          <FileText className="w-12 h-12 text-slate-900 dark:text-white mb-6" />
          <h3 class="text-3xl font-semibold mb-4 text-slate-900 dark:text-white">Custom Assessments</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-8 text-lg leading-relaxed">
            Create questionnaires with multiple question types (text, multiple choice, file upload). Automated scoring and routing based on responses.
          </p>
          <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400">
            <Award className="w-5 h-5 text-slate-900 dark:text-white" />
            <span>Manual review and feedback workflow included</span>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-10">
          <Zap className="w-12 h-12 text-slate-900 dark:text-white mb-6" />
          <h3 class="text-3xl font-semibold mb-4 text-slate-900 dark:text-white">Fraud Prevention</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-8 text-lg leading-relaxed">
            Real-time email validation, disposable email detection, VoIP phone screening, and configurable fraud thresholds protect your pipeline from spam applications.
          </p>
          <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400">
            <Shield className="w-5 h-5 text-slate-900 dark:text-white" />
            <span>99% spam reduction on average</span>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-10">
          <Globe className="w-12 h-12 text-slate-900 dark:text-white mb-6" />
          <h3 class="text-3xl font-semibold mb-4 text-slate-900 dark:text-white">Multi-Channel Communication</h3>
          <p class="text-slate-600 dark:text-slate-400 mb-8 text-lg leading-relaxed">
            Email and SMS integration with templates, quiet hours compliance, thread grouping, and full conversation history. All communications in one place.
          </p>
          <div class="flex items-center gap-3 text-sm text-slate-600 dark:text-slate-400">
            <Mail className="w-5 h-5 text-slate-900 dark:text-white" />
            <Phone className="w-5 h-5 text-slate-900 dark:text-white" />
            <span>SendGrid & Twilio powered</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Integration & Security -->
  <section class="py-28 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16 md:mb-20">
        <p class="text-xs sm:text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">
          [04] Security & Performance
        </p>
        <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-4 md:mb-6 leading-tight">
          Built to scale
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-6 lg:gap-8">
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-3xl p-10">
          <Shield className="w-14 h-14 text-slate-900 dark:text-white mb-8" />
          <h3 class="text-3xl font-semibold mb-6 text-slate-900 dark:text-white">Enterprise Security & Compliance</h3>
          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">GDPR & CCPA compliant with privacy hub</span>
            </div>
            <div class="flex items-center gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">SOC 2 Type II certified infrastructure</span>
            </div>
            <div class="flex items-center gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Role-based access control (RBAC)</span>
            </div>
            <div class="flex items-center gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Data encryption in transit and at rest</span>
            </div>
            <div class="flex items-center gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Multi-device session management</span>
            </div>
            <div class="flex items-center gap-4">
              <CheckCircle className="w-6 h-6 text-slate-900 dark:text-white flex-shrink-0" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Automated consent logging & audit trails</span>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-3xl font-semibold mb-8 text-slate-900 dark:text-white">Performance & Reliability</h3>
          <div class="grid grid-cols-2 gap-4 mb-10">
            <div class="text-center p-8 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-3">99.9%</div>
              <div class="text-sm text-slate-600 dark:text-slate-400 font-medium">Uptime SLA</div>
            </div>
            <div class="text-center p-8 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-3">&lt;100ms</div>
              <div class="text-sm text-slate-600 dark:text-slate-400 font-medium">API response</div>
            </div>
            <div class="text-center p-8 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-3">24/7</div>
              <div class="text-sm text-slate-600 dark:text-slate-400 font-medium">Monitoring</div>
            </div>
            <div class="text-center p-8 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-2xl">
              <div class="text-4xl font-bold text-slate-900 dark:text-white mb-3">Auto</div>
              <div class="text-sm text-slate-600 dark:text-slate-400 font-medium">Scaling</div>
            </div>
          </div>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
              <TrendingUp className="w-6 h-6 text-slate-900 dark:text-white" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Database indexes for sub-second queries</span>
            </div>
            <div class="flex items-center gap-4">
              <TrendingUp className="w-6 h-6 text-slate-900 dark:text-white" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Response compression (gzip/deflate)</span>
            </div>
            <div class="flex items-center gap-4">
              <TrendingUp className="w-6 h-6 text-slate-900 dark:text-white" />
              <span class="text-slate-600 dark:text-slate-400 text-lg">Stale-while-revalidate caching strategy</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-28 px-4 sm:px-6 lg:px-8 bg-slate-900 dark:bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white dark:text-slate-900 mb-8 leading-tight">
        Ready to transform your hiring?
      </h2>
      <p class="text-xl sm:text-2xl text-slate-400 dark:text-slate-600 mb-12 leading-relaxed">
        Join hundreds of companies using Jatura to hire better, faster.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-10">
        <a href="/login">
          <Button
            size="lg"
            class="bg-white dark:bg-slate-900 text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800 px-10 py-6 text-lg group shadow-lg"
          >
            Start free trial
            <ArrowRight className="ml-2 h-5 w-5 group-hover:translate-x-1 transition" />
          </Button>
        </a>
        <a href="/pricing">
          <Button
            size="lg"
            variant="outline"
