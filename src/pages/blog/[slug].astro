---
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import { format } from 'date-fns';

const API_BASE = 'https://app.jatura.com';
const { slug } = Astro.params;

const res = await fetch(`${API_BASE}/api/blog/posts/${slug}`);
if (!res.ok) {
  return Astro.redirect('/blog');
}
const post = await res.json();

const title = post.metaTitle || post.title;
const description = post.metaDescription || post.excerpt || '';
const canonicalUrl = `https://jatura.com/blog/${post.slug}`;

const schemaOrg = post ? [
  {
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.metaDescription || post.excerpt || '',
    "url": `https://jatura.com/blog/${slug}`,
    "datePublished": post.publishedAt || post.createdAt,
    "dateModified": post.updatedAt || post.publishedAt || post.createdAt,
    "author": {
      "@type": "Organization",
      "name": post.authorName || "Jatura Team",
      "url": "https://jatura.com"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Jatura",
      "logo": { "@type": "ImageObject", "url": "https://jatura.com/logo.png" }
    },
    "image": post.coverImage || `https://jatura.com/og-image.png`,
    "mainEntityOfPage": { "@type": "WebPage", "@id": `https://jatura.com/blog/${slug}` }
  }
] : [];

// Extract headings for table of contents
const headings = (post.content || '')
  .split('\n')
  .filter((line: string) => line.startsWith('## '))
  .map((line: string) => ({
    text: line.substring(3),
    id: line.substring(3).toLowerCase().replace(/[^a-z0-9]+/g, '-')
  }));

// Simple markdown-to-HTML conversion for blog content
function renderContent(content: string): string {
  if (!content) return '';
  return content
    .split('\n')
    .map((line: string) => {
      // Headings
      if (line.startsWith('### ')) {
        const text = line.substring(4);
        const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-');
        return `<h3 id="${id}">${processInline(text)}</h3>`;
      }
      if (line.startsWith('## ')) {
        const text = line.substring(3);
        const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-');
        return `<h2 id="${id}">${processInline(text)}</h2>`;
      }
      if (line.startsWith('# ')) {
        const text = line.substring(2);
        const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-');
        return `<h1 id="${id}">${processInline(text)}</h1>`;
      }
      // List items
      if (line.match(/^[-*]\s+/)) {
        const text = line.replace(/^[-*]\s+/, '');
        return `<li>${processInline(text)}</li>`;
      }
      if (line.match(/^\d+\.\s+/)) {
        const text = line.replace(/^\d+\.\s+/, '');
        return `<li>${processInline(text)}</li>`;
      }
      // Empty lines
      if (line.trim() === '') return '<div class="h-2"></div>';
      // Paragraphs
      if (line.trim()) return `<p>${processInline(line)}</p>`;
      return '';
    })
    .join('\n');
}

function processInline(text: string): string {
  return text
    .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2">$1</a>');
}

const renderedContent = renderContent(post.content);
---

<MarketingLayout {title} {description} {canonicalUrl} {schemaOrg} ogType="article">
  <article class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Back link -->
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white mb-8 group"
        data-testid="link-back-to-blog"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-hover:-translate-x-1 transition"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to blog
      </a>

      <!-- Meta -->
      <div class="flex items-center gap-4 text-sm text-slate-500 dark:text-slate-500 mb-6" data-testid="post-meta">
        {post.publishedAt && (
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <time datetime={post.publishedAt}>
              {format(new Date(post.publishedAt), "MMMM d, yyyy")}
            </time>
          </div>
        )}
        {post.readTimeMinutes && (
          <div class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{post.readTimeMinutes} min read</span>
          </div>
        )}
        {post.contentType && (
          <span class="px-2 py-1 bg-slate-100 dark:bg-slate-800 rounded text-xs">
            {post.contentType}
          </span>
        )}
      </div>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white mb-4 leading-tight" data-testid="post-title">
        {post.title}
      </h1>

      <!-- Share button -->
      <div class="mb-12">
        <button
          id="share-button"
          class="inline-flex items-center gap-2 px-3 py-1.5 border border-slate-200 dark:border-slate-700 rounded-md text-sm font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition w-fit"
          data-testid="button-share"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
          Share
        </button>
      </div>

      <!-- Layout: Sidebar + Content -->
      <div class="flex flex-col lg:flex-row gap-12 items-start">
        <!-- Table of Contents - Left Sidebar (sticky on desktop) -->
        {headings.length > 0 && (
          <aside class="w-full lg:w-64 lg:sticky lg:top-24 shrink-0" data-testid="table-of-contents">
            <div class="p-6 bg-slate-50 dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800">
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-4">Table of Contents</h3>
              <nav class="space-y-3">
                {headings.map((heading: { id: string; text: string }) => (
                  <a
                    href={`#${heading.id}`}
                    class="block text-sm text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors leading-snug"
                    data-testid={`toc-link-${heading.id}`}
                  >
                    {heading.text}
                  </a>
                ))}
              </nav>
            </div>
          </aside>
        )}

        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <div
            class="prose prose-base sm:prose-lg prose-slate dark:prose-invert max-w-none
              prose-headings:font-bold prose-headings:text-slate-900 dark:prose-headings:text-white prose-headings:scroll-mt-20
              prose-h2:text-xl sm:prose-h2:text-2xl md:prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
              prose-h3:text-lg sm:prose-h3:text-xl md:prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
              prose-p:text-slate-600 dark:prose-p:text-slate-400 prose-p:leading-relaxed prose-p:text-base sm:prose-p:text-lg
              prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
              prose-strong:text-slate-900 dark:prose-strong:text-white prose-strong:font-semibold
              prose-code:text-slate-900 dark:prose-code:text-white prose-code:bg-slate-100 dark:prose-code:bg-slate-800 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
              prose-ul:list-disc prose-ul:pl-6 prose-ul:my-6
              prose-ol:list-decimal prose-ol:pl-6 prose-ol:my-6
              prose-li:text-slate-600 dark:prose-li:text-slate-400 prose-li:my-2
              prose-blockquote:border-l-4 prose-blockquote:border-slate-300 dark:prose-blockquote:border-slate-700 prose-blockquote:pl-4 prose-blockquote:italic"
            data-testid="post-content"
            set:html={renderedContent}
          />

          <!-- CTA -->
          <div class="mt-16 p-8 bg-slate-50 dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800" data-testid="post-cta">
            <h3 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white mb-3">
              Ready to transform your hiring?
            </h3>
            <p class="text-base sm:text-lg text-slate-600 dark:text-slate-400 mb-6">
              Join hundreds of companies using Jatura to hire better, faster.
            </p>
            <div class="flex flex-col sm:flex-row gap-3">
              <a href="/signup">
                <button class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition" data-testid="button-cta-trial">
                  Start free trial
                </button>
              </a>
              <a href="/pricing">
                <button class="inline-flex items-center justify-center rounded-md border border-input bg-background px-6 py-3 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition" data-testid="button-cta-pricing">
                  View pricing
                </button>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>

  <script>
    document.getElementById('share-button')?.addEventListener('click', async () => {
      const url = window.location.href;
      if (navigator.share) {
        try {
          await navigator.share({ title: document.title, url });
        } catch (e) { /* user cancelled */ }
      } else {
        try {
          await navigator.clipboard.writeText(url);
          alert('Link copied to clipboard!');
        } catch (e) {
          alert('Failed to copy link');
        }
      }
    });
  </script>
</MarketingLayout>
